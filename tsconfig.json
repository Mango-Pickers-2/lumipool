{
  "include": ["src/**/*.ts", "src/**/*.tsx", "vite.config.ts", "eslint.config.js"],

  "compilerOptions": {
    "target": "ES2022",

    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "jsx": "react-jsx",

    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,

    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,

    "baseUrl": ".",

    "paths": {
      "@/*": ["src/*"]
    },

    "types": ["vite/client"]
  }
}
